<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}EventApp{% endblock %} — ISSAT</title>
    <script src="https://cdn.tailwindcss.com"></script>
    {% block stylesheets %}{% endblock %}
    <style>
        .nav-link {
            position: relative;
            padding-bottom: 2px;
        }
        .nav-link::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 0;
            height: 2px;
            background: white;
            transition: width 0.3s ease;
        }
        .nav-link:hover::after {
            width: 100%;
        }
        .dropdown:hover .dropdown-menu {
            display: block;
        }
    </style>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col">

    {# ===== NAVBAR ===== #}
    <nav class="bg-gradient-to-r from-blue-800 to-blue-900 shadow-lg sticky top-0 z-50">
        <div class="max-w-6xl mx-auto px-4">
            <div class="flex items-center justify-between h-16">

                {# Logo + Nom #}
                <a href="{{ path('app_events_index') }}"
                   class="flex items-center gap-3 text-white hover:opacity-90 transition">
                    <div class="bg-white bg-opacity-20 rounded-xl p-2">
                        <span class="text-2xl">🎪</span>
                    </div>
                    <div>
                        <span class="text-xl font-bold tracking-wide">EventApp</span>
                        <span class="hidden sm:block text-xs text-blue-300 -mt-1">ISSAT Sousse</span>
                    </div>
                </a>

                {# Liens centraux #}
                <div class="hidden md:flex items-center gap-6">
                    <a href="{{ path('app_events_index') }}"
                       class="nav-link text-blue-100 hover:text-white text-sm font-medium transition flex items-center gap-1">
                        <span>📅</span> Événements
                    </a>
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('admin_dashboard') }}"
                           class="nav-link text-blue-100 hover:text-white text-sm font-medium transition flex items-center gap-1">
                            <span>⚙️</span> Administration
                        </a>
                    {% endif %}
                </div>

                {# Zone utilisateur #}
                <div class="flex items-center gap-3">

                    {% if app.user %}

                        {# Badge utilisateur connecté #}
                        <div class="hidden sm:flex items-center gap-2 bg-white bg-opacity-10
                                    rounded-xl px-3 py-2 text-sm text-white">
                            <div class="w-7 h-7 bg-blue-400 rounded-full flex items-center
                                        justify-center font-bold text-xs uppercase">
                                {{ app.user.email|slice(0,1) }}
                            </div>
                            <div class="leading-tight">
                                <p class="font-semibold text-xs">
                                    {{ app.user.email|slice(0, 18) }}{% if app.user.email|length > 18 %}…{% endif %}
                                </p>
                                <p class="text-blue-300 text-xs">
                                    {% if is_granted('ROLE_ADMIN') %}Administrateur{% else %}Membre{% endif %}
                                </p>
                            </div>
                        </div>

                        {# Bouton déconnexion #}
                        <a href="{{ path('app_logout') }}"
                           class="flex items-center gap-1 bg-red-500 hover:bg-red-600
                                  text-white text-sm font-semibold px-4 py-2 rounded-xl
                                  transition shadow hover:shadow-md">
                            <span>👋</span>
                            <span class="hidden sm:inline">Déconnexion</span>
                        </a>

                    {% else %}

                        {# Boutons connexion / inscription #}
                        <a href="{{ path('app_register') }}"
                           class="hidden sm:flex items-center gap-1 text-blue-200
                                  hover:text-white text-sm font-medium transition nav-link">
                            S'inscrire
                        </a>

                        <a href="{{ path('app_login') }}"
                           class="flex items-center gap-1 bg-white text-blue-800
                                  hover:bg-blue-50 text-sm font-bold px-4 py-2
                                  rounded-xl transition shadow hover:shadow-md">
                            <span>🔐</span>
                            <span>Connexion</span>
                        </a>

                    {% endif %}
                </div>

            </div>
        </div>

        {# Barre colorée en bas de la nav #}
        <div class="h-0.5 bg-gradient-to-r from-blue-400 via-purple-400 to-blue-400 opacity-50"></div>
    </nav>

    {# ===== MESSAGES FLASH ===== #}
    {% set flashes = app.flashes %}
    {% if flashes is not empty %}
    <div class="max-w-6xl mx-auto px-4 mt-4 space-y-2">
        {% for label, messages in flashes %}
            {% for message in messages %}
                <div class="flex items-center gap-3 p-4 rounded-xl border font-medium text-sm
                    {% if label == 'success' %}
                        bg-green-50 border-green-300 text-green-800
                    {% elseif label == 'error' %}
                        bg-red-50 border-red-300 text-red-800
                    {% elseif label == 'warning' %}
                        bg-yellow-50 border-yellow-300 text-yellow-800
                    {% else %}
                        bg-blue-50 border-blue-300 text-blue-800
                    {% endif %}">
                    <span>
                        {% if label == 'success' %}✅
                        {% elseif label == 'error' %}⚠️
                        {% elseif label == 'warning' %}⚠️
                        {% else %}ℹ️{% endif %}
                    </span>
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}
    </div>
    {% endif %}

    {# ===== CONTENU PRINCIPAL ===== #}
    <main class="max-w-6xl mx-auto px-4 py-8 flex-1 w-full">
        {% block body %}{% endblock %}
    </main>

    {# ===== FOOTER ===== #}
    <footer class="bg-gray-800 text-gray-400 mt-auto">
        <div class="max-w-6xl mx-auto px-4 py-8">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">

                <div>
                    <div class="flex items-center gap-2 text-white font-bold text-lg mb-2">
                        <span>🎪</span> EventApp
                    </div>
                    <p class="text-sm text-gray-500">
                        Plateforme de gestion et réservation d'événements — ISSAT Sousse
                    </p>
                </div>

                <div>
                    <p class="text-white font-semibold text-sm mb-3">Navigation</p>
                    <ul class="space-y-2 text-sm">
                        <li>
                            <a href="{{ path('app_events_index') }}"
                               class="hover:text-white transition">📅 Événements</a>
                        </li>
                        {% if app.user %}
                        <li>
                            <a href="{{ path('app_logout') }}"
                               class="hover:text-white transition">👋 Déconnexion</a>
                        </li>
                        {% else %}
                        <li>
                            <a href="{{ path('app_login') }}"
                               class="hover:text-white transition">🔐 Connexion</a>
                        </li>
                        <li>
                            <a href="{{ path('app_register') }}"
                               class="hover:text-white transition">📝 S'inscrire</a>
                        </li>
                        {% endif %}
                    </ul>
                </div>

                <div>
                    <p class="text-white font-semibold text-sm mb-3">Technologies</p>
                    <div class="flex flex-wrap gap-2">
                        <span class="bg-gray-700 text-gray-300 text-xs px-3 py-1 rounded-full">Symfony 7</span>
                        <span class="bg-gray-700 text-gray-300 text-xs px-3 py-1 rounded-full">JWT</span>
                        <span class="bg-gray-700 text-gray-300 text-xs px-3 py-1 rounded-full">Passkeys</span>
                        <span class="bg-gray-700 text-gray-300 text-xs px-3 py-1 rounded-full">PHP 8.2</span>
                        <span class="bg-gray-700 text-gray-300 text-xs px-3 py-1 rounded-full">Docker</span>
                    </div>
                </div>

            </div>

            <div class="border-t border-gray-700 pt-4 flex flex-col sm:flex-row
                        justify-between items-center gap-2 text-xs text-gray-500">
                <span>© 2026 EventApp — ISSAT Sousse · FIA2-GL</span>
                <span>Symfony + JWT + Passkeys</span>
            </div>
        </div>
    </footer>

    {% block javascripts %}{% endblock %}
</body>
</html>
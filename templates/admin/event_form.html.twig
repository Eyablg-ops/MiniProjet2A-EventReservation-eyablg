{% extends 'base.html.twig' %}

{% block title %}{{ title }} — EventApp Admin{% endblock %}

{% block body %}

{# Breadcrumb #}
<nav class="flex items-center gap-2 text-sm text-gray-500 mb-6">
    <a href="{{ path('admin_dashboard') }}" class="hover:text-blue-600 transition">⚙️ Dashboard</a>
    <span class="text-gray-300">›</span>
    <span class="text-gray-700 font-semibold">{{ title }}</span>
</nav>

<div class="max-w-3xl mx-auto">

    {# Header #}
    <div class="bg-gradient-to-r from-blue-700 to-blue-900 rounded-2xl p-8 mb-8 text-white shadow-lg">
        <div class="flex items-center gap-4">
            <div class="bg-white bg-opacity-20 rounded-xl p-3">
                <span class="text-3xl">{{ event and event.id ? '✏️' : '➕' }}</span>
            </div>
            <div>
                <h1 class="text-3xl font-bold">{{ title }}</h1>
                <p class="text-blue-200 mt-1">
                    {{ event and event.id
                        ? 'Modifiez les informations de l\'événement'
                        : 'Remplissez les informations pour créer un nouvel événement' }}
                </p>
            </div>
        </div>
    </div>

    {# Formulaire principal #}
    <div class="bg-white rounded-2xl shadow-lg overflow-hidden">

        {{ form_start(form, {'attr': {'class': 'divide-y divide-gray-100', 'novalidate': 'novalidate'}}) }}

            {# Section 1 — Informations principales #}
            <div class="p-8">
                <div class="flex items-center gap-3 mb-6">
                    <div class="bg-blue-100 rounded-xl p-2 text-xl">📝</div>
                    <div>
                        <h2 class="text-lg font-bold text-gray-800">Informations principales</h2>
                        <p class="text-sm text-gray-500">Titre et description de l'événement</p>
                    </div>
                </div>
                <div class="space-y-5">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">
                            Titre de l'événement <span class="text-red-500">*</span>
                        </label>
                        {{ form_widget(form.title, {
                            'attr': {
                                'class': 'w-full border border-gray-300 rounded-xl px-4 py-3
                                         text-gray-800 focus:outline-none focus:ring-2
                                         focus:ring-blue-500 focus:border-transparent
                                         transition placeholder-gray-400 text-base',
                                'placeholder': 'Ex: Conférence Symfony 2026'
                            }
                        }) }}
                        {{ form_errors(form.title) }}
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">
                            Description
                        </label>
                        {{ form_widget(form.description, {
                            'attr': {
                                'class': 'w-full border border-gray-300 rounded-xl px-4 py-3
                                         text-gray-800 focus:outline-none focus:ring-2
                                         focus:ring-blue-500 focus:border-transparent
                                         transition placeholder-gray-400 resize-none',
                                'placeholder': 'Décrivez votre événement en quelques phrases...',
                                'rows': 4
                            }
                        }) }}
                        {{ form_errors(form.description) }}
                    </div>
                </div>
            </div>

            {# Section 2 — Date et lieu #}
            <div class="p-8">
                <div class="flex items-center gap-3 mb-6">
                    <div class="bg-green-100 rounded-xl p-2 text-xl">📅</div>
                    <div>
                        <h2 class="text-lg font-bold text-gray-800">Date et lieu</h2>
                        <p class="text-sm text-gray-500">Quand et où se déroule l'événement</p>
                    </div>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">
                            Date et heure <span class="text-red-500">*</span>
                        </label>
                        {{ form_widget(form.date, {
                            'attr': {
                                'class': 'w-full border border-gray-300 rounded-xl px-4 py-3
                                         text-gray-800 focus:outline-none focus:ring-2
                                         focus:ring-blue-500 focus:border-transparent transition'
                            }
                        }) }}
                        {{ form_errors(form.date) }}
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">
                            Lieu
                        </label>
                        {{ form_widget(form.location, {
                            'attr': {
                                'class': 'w-full border border-gray-300 rounded-xl px-4 py-3
                                         text-gray-800 focus:outline-none focus:ring-2
                                         focus:ring-blue-500 focus:border-transparent
                                         transition placeholder-gray-400',
                                'placeholder': 'Ex: Salle A1, ISSAT Sousse'
                            }
                        }) }}
                        {{ form_errors(form.location) }}
                    </div>
                </div>
            </div>

            {# Section 3 — Capacité et image #}
            <div class="p-8">
                <div class="flex items-center gap-3 mb-6">
                    <div class="bg-purple-100 rounded-xl p-2 text-xl">🎟️</div>
                    <div>
                        <h2 class="text-lg font-bold text-gray-800">Capacité et image</h2>
                        <p class="text-sm text-gray-500">Places disponibles et illustration</p>
                    </div>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">
                            Nombre de places
                        </label>
                        {{ form_widget(form.seats, {
                            'attr': {
                                'class': 'w-full border border-gray-300 rounded-xl px-4 py-3
                                         text-gray-800 focus:outline-none focus:ring-2
                                         focus:ring-blue-500 focus:border-transparent transition',
                                'placeholder': 'Ex: 50',
                                'min': 1
                            }
                        }) }}
                        {{ form_errors(form.seats) }}
                        <p class="text-xs text-gray-400 mt-1">Laissez vide pour un nombre illimité</p>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">
                            URL de l'image
                        </label>
                        {{ form_widget(form.image, {
                            'attr': {
                                'class': 'w-full border border-gray-300 rounded-xl px-4 py-3
                                         text-gray-800 focus:outline-none focus:ring-2
                                         focus:ring-blue-500 focus:border-transparent
                                         transition placeholder-gray-400',
                                'placeholder': 'https://exemple.com/image.jpg',
                                'id': 'imageUrlInput'
                            }
                        }) }}
                        {{ form_errors(form.image) }}
                        <p class="text-xs text-gray-400 mt-1">Lien direct vers une image (jpg, png, webp)</p>
                    </div>
                </div>

                {# Prévisualisation image #}
                <div id="imagePreviewBox" class="mt-5 hidden">
                    <p class="text-sm font-semibold text-gray-700 mb-2">Prévisualisation :</p>
                    <div class="relative rounded-xl overflow-hidden border border-gray-200 bg-gray-50"
                         style="height: 200px">
                        <img id="imagePreview" src="" alt="Prévisualisation"
                             class="w-full h-full object-cover">
                    </div>
                </div>

                {% if event and event.image %}
                    <div class="mt-5">
                        <p class="text-sm font-semibold text-gray-700 mb-2">Image actuelle :</p>
                        <div class="rounded-xl overflow-hidden border border-gray-200" style="height: 180px">
                            <img src="{{ event.image }}" alt="{{ event.title }}"
                                 class="w-full h-full object-cover">
                        </div>
                    </div>
                {% endif %}
            </div>

            {# Section 4 — Boutons d'action du formulaire principal UNIQUEMENT #}
            <div class="p-8 bg-gray-50">
                <div class="flex flex-col sm:flex-row gap-3 justify-between items-center">
                    <a href="{{ path('admin_dashboard') }}"
                       class="w-full sm:w-auto flex items-center justify-center gap-2
                              border-2 border-gray-300 text-gray-600 hover:bg-gray-100
                              font-semibold py-3 px-6 rounded-xl transition order-2 sm:order-1">
                        ← Annuler
                    </a>
                    {{ form_widget(form.save, {
                        'attr': {
                            'class': 'w-full sm:w-auto flex items-center justify-center gap-2
                                     bg-blue-600 hover:bg-blue-700 text-white font-bold
                                     py-3 px-8 rounded-xl transition shadow-md
                                     hover:shadow-lg cursor-pointer text-base order-1 sm:order-2'
                        }
                    }) }}
                </div>
            </div>

        {{ form_end(form) }}
        {# ✅ form_end ICI — formulaire principal fermé proprement #}

    </div>
    {# ✅ fin du div bg-white #}

</div>
{# ✅ fin du div max-w-3xl #}

{# ===== BOUTON SUPPRIMER — COMPLÈTEMENT EN DEHORS DU FORM PRINCIPAL ===== #}
{% if event and event.id %}
<div class="max-w-3xl mx-auto mt-4">
    <form method="post"
          action="{{ path('admin_event_delete', {id: event.id}) }}"
          onsubmit="return confirm('Supprimer définitivement « {{ event.title }} » et toutes ses réservations ?')">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}">
        <button type="submit"
                class="w-full flex items-center justify-center gap-2
                       bg-red-50 hover:bg-red-100 text-red-600
                       font-semibold py-3 px-6 rounded-xl transition
                       border border-red-200">
            🗑️ Supprimer cet événement
        </button>
    </form>
</div>
{% endif %}

{% endblock %}

{% block javascripts %}
<script>
    const input = document.getElementById('imageUrlInput');
    const previewBox = document.getElementById('imagePreviewBox');
    const preview = document.getElementById('imagePreview');

    if (input) {
        function updatePreview() {
            const url = input.value.trim();
            if (url && (url.startsWith('http://') || url.startsWith('https://'))) {
                preview.src = url;
                previewBox.classList.remove('hidden');
                preview.onerror = () => { previewBox.classList.add('hidden'); };
            } else {
                previewBox.classList.add('hidden');
            }
        }
        input.addEventListener('input', updatePreview);
        updatePreview();
    }
</script>
{% endblock %}